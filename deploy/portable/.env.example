# setup.sh creates .env and replaces every CHANGE_ME value. Keep .env out of Git.
COMPOSE_PROJECT_NAME=yakmogo
YAKMOGO_IMAGE=yakmogo:0.0.7
YAKMOGO_BIND_ADDRESS=0.0.0.0
YAKMOGO_HTTP_PORT=8080
YAKMOGO_FRONTEND_URL=http://localhost:8080

YAKMOGO_DB_NAME=yakmogo
YAKMOGO_DB_USER=yakmogo_app
YAKMOGO_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
YAKMOGO_DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD

ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
AUTH_TOKEN_SECRET=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_BYTES
AUTH_TOKEN_TTL_SECONDS=3600
AUTH_LOGIN_PROOF_TTL_SECONDS=300

TELEGRAM_BOT_ENABLED=false
SCHEDULING_ENABLED=false
TELEGRAM_BOT_TOKEN=disabled
TELEGRAM_BOT_USERNAME=yakson_bot
TELEGRAM_CHAT_ID=disabled
