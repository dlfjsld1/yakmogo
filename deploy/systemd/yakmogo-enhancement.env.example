# Install as /etc/yakmogo/yakmogo-enhancement.env with root:root ownership and mode 600.
# Never commit the installed file or replace these placeholders with real values.
SPRING_PROFILES_ACTIVE=enhancement
YAKMOGO_DB_PASSWORD=CHANGE_ME
TELEGRAM_BOT_TOKEN=disabled-in-enhancement
TELEGRAM_CHAT_ID=disabled-in-enhancement
ADMIN_PASSWORD=CHANGE_ME
AUTH_TOKEN_SECRET=CHANGE_ME_TO_A_RANDOM_VALUE_OF_AT_LEAST_32_BYTES
FRONTEND_URL=http://PI_LAN_IP:8081
